<?xml version="1.0"?>
<launch>
    <!-- Simplified version: Run robot_localization EKF only -->
    
    <arg name="ekf_config" default="/root/data/ekf_config.yaml"/>
    <param name="/use_sim_time" value="true"/>
    
    <!-- TF Static Transform (Fix IMU to base_link missing transform) -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="base_to_imu"
          args="0 0 0 0 0 0 base_link imu"/>

    <!-- TF Static Transform (world to odom) to allow EKF to use data in 'world' frame -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="world_to_odom"
          args="0 0 0 0 0 0 world odom"/>

    <!-- Topic transform for Star Tracker (Quaternion -> PoseWithCovarianceStamped) 
         Note: Expression must not have spaces to be parsed correctly as a single argument by roslaunch/topic_tools
    -->
    <!-- Topic transform for Star Tracker (Quaternion -> PoseWithCovarianceStamped) -->
    <!-- Added respawn="true" to wait for the bag to start publishing the topic -->
    <node pkg="topic_tools" type="transform" name="star_tracker_to_pose"
          args="/star_tracker/attitude /star_tracker/pose geometry_msgs/PoseWithCovarianceStamped
          'geometry_msgs.msg.PoseWithCovarianceStamped(header=m.header,pose=geometry_msgs.msg.PoseWithCovariance(pose=geometry_msgs.msg.Pose(position=geometry_msgs.msg.Point(x=0,y=0,z=0),orientation=m.quaternion),covariance=[1e-6,0,0,0,0,0,0,0,1e-6,0,0,0,0,0,0,0,1e-6,0,0,0,0,0,0,0,1e-6,0,0,0,0,0,0,0,1e-6,0,0,0,0,0,0,0,1e-6]))'
          --import geometry_msgs std_msgs"
          output="screen"
          respawn="true" />
    
    <!-- robot_localization EKF node -->
    <node pkg="robot_localization" type="ekf_localization_node" name="ekf_localization"
          output="screen" clear_params="true">
        <rosparam command="load" file="$(arg ekf_config)"/>
        <remap from="odometry/filtered" to="/ekf/odometry"/>
    </node>
    
</launch>